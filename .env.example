# .env.example
# Copy to .env.local and fill in values. Never commit .env.local.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://simplerms:simplerms_dev@localhost:5432/simplerms"

# ── Auth.js ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-secret"

# ── Encryption (API key storage) ─────────────────────────────────────────────
# 32-byte hex string. Generate with: openssl rand -hex 32
APP_ENCRYPTION_KEY="replace-with-32-byte-hex-key"

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# In dev, point at Mailpit: host=localhost port=1025
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="Akritos <noreply@example.com>"

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
